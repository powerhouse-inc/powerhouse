{
  "name": "document-drive",
  "version": "6.0.0-dev.105",
  "license": "AGPL-3.0-only",
  "type": "module",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/powerhouse-inc/powerhouse"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./storage/filesystem": {
      "import": "./dist/storage/filesystem.mjs",
      "types": "./dist/storage/filesystem.d.mts"
    },
    "./storage/prisma": {
      "import": "./dist/storage/prisma.mjs",
      "types": "./dist/storage/prisma.d.mts"
    },
    "./storage/prisma/client": {
      "import": "./src/storage/prisma/client/default.js",
      "types": "./src/storage/prisma/client/default.d.ts"
    }
  },
  "files": [
    "./dist",
    "./prisma/schema.prisma",
    "./src/storage/prisma/client"
  ],
  "sideEffects": false,
  "scripts": {
    "tsc": "tsc",
    "lint": "eslint",
    "build:misc": "pnpm run copy-prisma",
    "build:bundle": "tsx ./bundle.ts",
    "release": "semantic-release",
    "test:legacy": "vitest run --coverage --exclude \"test/flaky/**\"",
    "test:flaky": "vitest run --coverage test/flaky",
    "test:watch": "vitest --coverage --exclude \"test/flaky/**\"",
    "bench": "vitest bench",
    "migrate": "prisma generate && prisma db push --skip-generate",
    "copy-prisma": "copyfiles prisma/schema.prisma dist/ && copyfiles 'src/storage/prisma/client/**/*' dist/",
    "prisma-generate": "prisma generate --no-hints && pnpm copy-prisma"
  },
  "dependencies": {
    "redis": "^4.6.15",
    "sequelize": "^6.37.3",
    "sqlite3": "^5.1.7",
    "@powerhousedao/analytics-engine-core": "workspace:*",
    "@powerhousedao/shared": "workspace:*",
    "@prisma/client": "5.17.0",
    "@sindresorhus/fnv1a": "catalog:",
    "change-case": "catalog:",
    "document-model": "workspace:*",
    "exponential-backoff": "^3.1.1",
    "graphql": "catalog:",
    "graphql-request": "catalog:",
    "json-stringify-deterministic": "^1.0.12",
    "kysely": "catalog:",
    "localforage": "^1.10.0",
    "lru-cache": "^11.1.0",
    "nanoevents": "^9.0.0",
    "object-sizeof": "^2.6.5",
    "prisma": "5.17.0",
    "zocker": "catalog:",
    "zod": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vitest-fetch-mock": "^0.4.5",
    "fake-indexeddb": "^5.0.2",
    "msw": "^2.3.1"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "^3.2.4",
    "copyfiles": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:"
  }
}