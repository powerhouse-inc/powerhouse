{
  "extends": "../../tsconfig.options.json",
  "compilerOptions": {
    "outDir": "./dist",
    "paths": {
      "cache": ["./src/cache/index.ts"],
      "utils": ["./src/utils/index.ts"],
      "processors": ["./src/processors/index.ts"],
      "queue": ["./src/queue/index.ts"],
      "server": ["./src/server/index.ts"],
      "read-mode": ["./src/read-mode/index.ts"],
      "storage": ["./src/storage/index.ts"],
      "storage/filesystem": ["./src/storage/filesystem.mts"],
      "storage/prisma": ["./src/storage/prisma/index.mts"],
      "storage/prisma/client": ["./src/storage/prisma/client/default.js"],
      "storage/*": ["./src/storage/*"]
    }
  },
  "include": [
    "**/*",
    "test/benchmarks/getDrive.json",
    "test/benchmarks/strands.small.json"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "coverage",
    "test/flaky/**"
  ],
  "references": [
    {
      "path": "../analytics-engine/core"
    },
    {
      "path": "../document-model"
    },
    {
      "path": "../shared"
    }
  ]
}
