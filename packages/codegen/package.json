{
  "name": "@powerhousedao/codegen",
  "version": "6.0.0-dev.118",
  "license": "AGPL-3.0-only",
  "private": false,
  "type": "module",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/powerhouse-inc/powerhouse"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./templates": {
      "types": "./dist/src/templates/index.d.mts",
      "import": "./dist/src/templates/index.mjs"
    },
    "./file-builders": {
      "types": "./dist/src/file-builders/index.d.mts",
      "import": "./dist/src/file-builders/index.mjs"
    },
    "./name-builders": {
      "types": "./dist/src/name-builders/index.d.mts",
      "import": "./dist/src/name-builders/index.mjs"
    },
    "./utils": {
      "types": "./dist/src/utils/index.d.mts",
      "import": "./dist/src/utils/index.mjs"
    }
  },
  "scripts": {
    "tsc": "tsc",
    "lint": "eslint",
    "copy-hygen": "rm -rf dist/src/codegen/.hygen && cp -r src/codegen/.hygen dist/src/codegen/",
    "build:bundle": "tsdown"
  },
  "dependencies": {
    "document-model": "workspace:",
    "@powerhousedao/document-engineering": "catalog:",
    "@graphql-codegen/add": "^6.0.0",
    "@graphql-codegen/cli": "catalog:",
    "@graphql-codegen/typescript": "catalog:",
    "@powerhousedao/shared": "workspace:*",
    "@tmpl/core": "npm:@jsr/tmpl__core@^0.6.3",
    "arg": "^5.0.2",
    "chalk": "catalog:",
    "change-case": "catalog:",
    "enquirer": "catalog:",
    "execa": "^8.0.1",
    "graphql": "catalog:",
    "graphql-codegen-typescript-validation-schema": "catalog:",
    "hygen": "^6.2.11",
    "prettier": "catalog:",
    "semver": "catalog:",
    "ts-morph": "catalog:",
    "@types/node": "catalog:",
    "tsdown": "catalog:"
  }
}
