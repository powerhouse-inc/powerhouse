{
  "name": "@powerhousedao/codegen",
  "version": "6.0.0-dev.109",
  "license": "AGPL-3.0-only",
  "private": false,
  "type": "module",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/powerhouse-inc/powerhouse"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./templates": {
      "types": "./dist/src/templates/index.d.ts",
      "default": "./dist/src/templates/index.js"
    },
    "./file-builders": {
      "types": "./dist/src/file-builders/index.d.ts",
      "default": "./dist/src/file-builders/index.js"
    },
    "./name-builders": {
      "types": "./dist/src/name-builders/index.d.ts",
      "default": "./dist/src/name-builders/index.js"
    },
    "./utils": {
      "types": "./dist/src/utils/index.d.ts",
      "default": "./dist/src/utils/index.js"
    }
  },
  "scripts": {
    "tsc": "tsc",
    "lint": "eslint",
    "build:create-lib": "tsc --project src/create-lib/tsconfig.json",
    "publish:create-lib": "npm publish --cwd ./src/create-lib/",
    "start": "tsx src/cli.ts",
    "test:bun": "bun test --concurrent --timeout 1000000",
    "test:vitest": "vitest --run",
    "test": "pnpm test:bun generate-doc-model.test.ts generate-processor.test.ts && pnpm test:vitest",
    "test:keep": "KEEP_TEST_OUTPUT=true pnpm test"
  },
  "dependencies": {
    "@graphql-codegen/add": "^6.0.0",
    "@graphql-codegen/cli": "catalog:",
    "@graphql-codegen/typescript": "catalog:",
    "@powerhousedao/common": "workspace:*",
    "@powerhousedao/config": "workspace:*",
    "@powerhousedao/document-engineering": "catalog:",
    "@powerhousedao/shared": "workspace:*",
    "@tmpl/core": "npm:@jsr/tmpl__core@^0.6.3",
    "@types/node": "catalog:",
    "arg": "^5.0.2",
    "chalk": "catalog:",
    "change-case": "catalog:",
    "document-model": "workspace:*",
    "graphql": "catalog:",
    "graphql-codegen-typescript-validation-schema": "catalog:",
    "package-json-validator": "^0.60.0",
    "prettier": "catalog:",
    "read-pkg": "catalog:",
    "semver": "catalog:",
    "ts-morph": "catalog:",
    "zocker": "^3.0.0"
  },
  "devDependencies": {
    "@powerhousedao/analytics-engine-core": "workspace:*",
    "@powerhousedao/design-system": "workspace:*",
    "@powerhousedao/reactor-browser": "workspace:*",
    "@types/bun": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  }
}
