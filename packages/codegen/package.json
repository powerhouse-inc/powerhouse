{
  "name": "@powerhousedao/codegen",
  "version": "6.0.0-dev.257",
  "license": "AGPL-3.0-only",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/powerhouse-inc/powerhouse"
  },
  "exports": {
    ".": {
      "source": "./index.mts",
      "import": "./dist/index.mjs"
    },
    "./templates": {
      "source": "./src/templates/index.mts",
      "import": "./dist/src/templates/index.mjs"
    },
    "./file-builders": {
      "source": "./src/file-builders/index.mts",
      "import": "./dist/src/file-builders/index.mjs"
    },
    "./name-builders": {
      "source": "./src/name-builders/index.mts",
      "import": "./dist/src/name-builders/index.mjs"
    },
    "./utils": {
      "source": "./src/utils/index.mts",
      "import": "./dist/src/utils/index.mjs"
    }
  },
  "scripts": {
    "tsc": "tsc",
    "lint": "eslint",
    "copy-hygen": "rm -rf dist/src/codegen/.hygen && cp -r src/codegen/.hygen dist/src/codegen/",
    "build": "tsdown"
  },
  "dependencies": {
    "@graphql-codegen/add": "catalog:",
    "@graphql-codegen/cli": "catalog:",
    "@graphql-codegen/typescript": "catalog:",
    "@powerhousedao/document-engineering": "catalog:",
    "@powerhousedao/shared": "workspace:*",
    "@types/node": "catalog:",
    "arg": "^5.0.2",
    "chalk": "catalog:",
    "change-case": "catalog:",
    "document-model": "workspace:*",
    "graphql-codegen-typescript-validation-schema": "catalog:",
    "load-json-file": "^7.0.1",
    "npm-registry-fetch": "^19.1.1",
    "prettier": "catalog:",
    "read-pkg": "catalog:",
    "remeda": "catalog:",
    "ts-morph": "catalog:",
    "write-json-file": "^7.0.0",
    "write-package": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@pnpm/find-workspace-dir": "^1000.1.5",
    "@pnpm/find-workspace-packages": "^6.0.9",
    "@tmpl/core": "npm:@jsr/tmpl__core@^0.6.3",
    "@types/npm-registry-fetch": "^8.0.9",
    "graphql": "catalog:",
    "tsdown": "catalog:"
  },
  "peerDependencies": {
    "graphql": "^16"
  }
}
