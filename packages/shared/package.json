{
  "name": "@powerhousedao/shared",
  "version": "6.2.0-dev.6",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/powerhouse-inc/powerhouse"
  },
  "scripts": {
    "build": "tsx ./bundle.ts",
    "test": "vitest --run"
  },
  "exports": {
    ".": {
      "source": "./index.ts",
      "import": "./dist/index.js"
    },
    "./processors": {
      "source": "./processors/index.ts",
      "import": "./dist/processors/index.js"
    },
    "./processors/*": {
      "source": "./processors/*.ts",
      "import": "./dist/processors/*.js"
    },
    "./document-model": {
      "source": "./document-model/index.ts",
      "import": "./dist/document-model/index.js"
    },
    "./document-model/*": {
      "source": "./document-model/*.ts",
      "import": "./dist/document-model/*.js"
    },
    "./document-drive": {
      "source": "./document-drive/index.ts",
      "import": "./dist/document-drive/index.js"
    },
    "./document-drive/*": {
      "source": "./document-drive/*.ts",
      "import": "./dist/document-drive/*.js"
    },
    "./connect": {
      "source": "./connect/index.ts",
      "import": "./dist/connect/index.js"
    },
    "./connect/*": {
      "source": "./connect/*.ts",
      "import": "./dist/connect/*.js"
    },
    "./analytics": {
      "source": "./analytics/index.ts",
      "import": "./dist/analytics/index.js"
    },
    "./analytics/*": {
      "source": "./analytics/*.ts",
      "import": "./dist/analytics/*.js"
    },
    "./registry": {
      "source": "./registry/index.ts",
      "import": "./dist/registry/index.js"
    },
    "./registry/*": {
      "source": "./registry/*.ts",
      "import": "./dist/registry/*.js"
    },
    "./constants": {
      "source": "./constants.ts",
      "import": "./dist/constants.js"
    },
    "./clis": {
      "source": "./clis/index.mts",
      "import": "./dist/clis/index.mjs"
    },
    "./clis/args": {
      "source": "./clis/args/index.ts",
      "import": "./dist/clis/args/index.mjs"
    },
    "./clis/args/*": {
      "source": "./clis/args/*.ts",
      "import": "./dist/clis/args/*.mjs"
    },
    "./clis/constants": {
      "source": "./clis/constants.ts",
      "import": "./dist/clis/constants.mjs"
    },
    "./clis/utils": {
      "source": "./clis/utils.ts",
      "import": "./dist/clis/utils.mjs"
    },
    "./clis/command-names": {
      "source": "./clis/command-names.ts",
      "import": "./dist/clis/command-names.mjs"
    },
    "./clis/telemetry": {
      "source": "./clis/services/telemetry.ts",
      "import": "./dist/clis/services/telemetry.mjs"
    },
    "./build-config": {
      "source": "./clis/build-config.mts",
      "import": "./dist/clis/build-config.mjs"
    }
  },
  "dependencies": {
    "@sindresorhus/fnv1a": "catalog:",
    "chalk": "catalog:",
    "change-case": "catalog:",
    "cmd-ts": "catalog:",
    "enquirer": "catalog:",
    "fflate": "^0.8.2",
    "kysely": "catalog:",
    "luxon": "catalog:",
    "mutative": "catalog:",
    "npm-package-arg": "catalog:",
    "package-directory": "^8.1.0",
    "package-manager-detector": "catalog:",
    "remeda": "catalog:",
    "safe-stable-stringify": "^2.4.3",
    "sha1-uint8array": "^0.10.7",
    "write-package": "catalog:",
    "zocker": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@sentry/node-core": "^10.52.0",
    "@types/bun": "catalog:",
    "@types/luxon": "catalog:",
    "@types/node": "catalog:",
    "@types/npm-package-arg": "catalog:",
    "@types/react": "catalog:",
    "react": "catalog:",
    "rolldown": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@sentry/node-core": "^10.52.0",
    "rolldown": "catalog:"
  },
  "peerDependenciesMeta": {
    "@sentry/node-core": {
      "optional": true
    },
    "rolldown": {
      "optional": true
    }
  }
}
