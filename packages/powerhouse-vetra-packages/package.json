{
  "name": "@powerhousedao/powerhouse-vetra-packages",
  "version": "6.0.0-dev.163",
  "description": "",
  "keywords": [],
  "author": "",
  "license": "AGPL-3.0-only",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/powerhouse-inc/powerhouse"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser/index.js",
      "node": "./dist/node/index.mjs"
    },
    "./document-models": {
      "types": "./dist/document-models/index.d.ts",
      "browser": "./dist/browser/document-models/index.js",
      "node": "./dist/node/document-models/index.mjs"
    },
    "./document-models/*": {
      "types": "./dist/document-models/*/index.d.ts",
      "browser": "./dist/browser/document-models/*/index.js",
      "node": "./dist/node/document-models/*/index.mjs"
    },
    "./editors": {
      "types": "./dist/editors/index.d.ts",
      "browser": "./dist/browser/editors/index.js",
      "node": "./dist/node/editors/index.mjs"
    },
    "./editors/*": {
      "types": "./dist/editors/*/index.d.ts",
      "browser": "./dist/browser/editors/*/index.js",
      "node": "./dist/node/editors/*/index.mjs"
    },
    "./subgraphs": {
      "types": "./dist/subgraphs/index.d.ts",
      "browser": "./dist/browser/subgraphs/index.js",
      "node": "./dist/node/subgraphs/index.mjs"
    },
    "./processors": {
      "types": "./dist/processors/index.d.ts",
      "browser": "./dist/browser/processors/index.js",
      "node": "./dist/node/processors/index.mjs"
    },
    "./manifest": "./dist/powerhouse.manifest.json",
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "tsc": "tsc",
    "lint": "eslint",
    "build:css": "pnpm exec tailwindcss -i ./style.css -o ./dist/style.css",
    "test": "vitest --run",
    "build": "tsx ./build && pnpm build:css",
    "test:watch": "vitest",
    "generate": "ph-cli generate",
    "reactor": "ph-cli reactor",
    "service": "ph-cli service",
    "migrate": "ph-cli migrate",
    "service-startup": "bash ./node_modules/@powerhousedao/ph-cli/dist/scripts/service-startup.sh",
    "service-unstartup": "bash ./node_modules/@powerhousedao/ph-cli/dist/scripts/service-unstartup.sh"
  },
  "dependencies": {
    "react-i18next": "catalog:",
    "@codemirror/autocomplete": "6.18.6",
    "@codemirror/commands": "6.8.1",
    "@codemirror/lang-json": "6.0.1",
    "@codemirror/language": "6.11.0",
    "@codemirror/lint": "6.8.5",
    "@codemirror/search": "6.5.10",
    "@codemirror/state": "6.5.2",
    "@tanstack/react-virtual": "^3.8.1",
    "@codemirror/view": "6.36.7",
    "@graphql-tools/utils": "catalog:",
    "@powerhousedao/design-system": "workspace:*",
    "@powerhousedao/reactor-browser": "workspace:*",
    "@powerhousedao/document-engineering": "catalog:",
    "@powerhousedao/shared": "workspace:*",
    "@radix-ui/react-label": "^2.1.4",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-tabs": "^1.1.9",
    "change-case": "catalog:",
    "class-variance-authority": "0.7.0",
    "clsx": "^2.1.1",
    "cm6-graphql": "^0.2.1",
    "document-model": "workspace:*",
    "graphql": "catalog:",
    "react-hook-form": "^7.56.1",
    "tailwind-merge": "catalog:",
    "thememirror": "^2.0.1",
    "validator": "^13.15.0",
    "@hookform/resolvers": "^5.0.1",
    "zod": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/validator": "^13.12.2",
    "tsdown": "catalog:",
    "tailwindcss": "catalog:",
    "@tailwindcss/cli": "catalog:",
    "tsx": "catalog:"
  }
}
