{
  "name": "@powerhousedao/registry",
  "version": "6.2.1",
  "description": "Powerhouse package registry — resolves and manages document model package dependencies within the Powerhouse ecosystem.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/powerhouse-inc/powerhouse",
    "directory": "packages/registry"
  },
  "bin": {
    "ph-registry": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "static"
  ],
  "sideEffects": false,
  "scripts": {
    "start": "node ./dist/cli.mjs",
    "dev": "bun run ./cli.ts",
    "build": "tsdown",
    "postbuild": "bun run ./copy-dirs.ts",
    "test": "vitest --run"
  },
  "keywords": [
    "powerhouse",
    "vetra",
    "document-model",
    "local-first",
    "event-sourcing",
    "registry",
    "packages",
    "dependencies"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@powerhousedao/shared": "workspace:*",
    "@renown/sdk": "workspace:*",
    "@verdaccio/signature": "8.0.0-next-8.29",
    "cmd-ts": "catalog:",
    "express": "^4.22.1",
    "find-up": "^8.0.0",
    "tar": "^7.5.11",
    "verdaccio": "^6.5.0",
    "verdaccio-aws-s3-storage": "^10.4.0"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "@types/express": "^4.17.21",
    "@types/node": "catalog:",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.1.0",
    "vitest": "catalog:"
  },
  "homepage": "https://academy.vetra.io"
}
