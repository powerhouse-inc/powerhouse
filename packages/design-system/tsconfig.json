{
  "extends": "../../tsconfig.options.json",
  "compilerOptions": {
    "outDir": "./.tsbuild",
    "resolveJsonModule": true,
    "lib": ["esnext", "DOM", "DOM.Iterable"],
    "types": [
      "vite/client",
      "@storybook/types",
      "node",
      "vitest/globals",
      "@testing-library/jest-dom"
    ]
  },
  "references": [
    {
      "path": "../config"
    },
    {
      "path": "../reactor-browser"
    },
    {
      "path": "../shared"
    }
  ],
  "include": ["**/*"],
  "exclude": ["node_modules", "dist", "storybook-static"]
}
