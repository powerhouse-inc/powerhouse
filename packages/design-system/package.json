  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/powerhouse-inc/powerhouse"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "imports": {
    "#design-system": "./src/index.ts",
    "#design-system/ui": "./src/ui/index.ts",
    "#design-system/ui/lib": "./src/ui/lib/index.ts",
    "#design-system/ui/*": "./src/ui/*",
    "#design-system/connect": "./src/connect/index.ts",
    "#assets/*": "./assets/*"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    },
    "./ui": {
      "source": "./src/ui/index.ts",
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    },
    "./ui/lib": {
      "source": "./src/ui/lib/index.ts",
      "types": "./dist/ui/lib/index.d.ts",
      "import": "./dist/ui/lib/index.js"
    },
    "./ui/*": "./dist/ui/*",
    "./connect": {
      "source": "./src/connect/index.ts",
      "types": "./dist/connect/index.d.ts",
      "import": "./dist/connect/index.js"
    },
    "./connect/toast": {
      "source": "./src/connect/components/toast/toast.tsx",
      "types": "./dist/connect/components/toast/toast.d.ts",
      "import": "./dist/connect/components/toast/toast.js"
    },
    "./style.css": ["./dist/style.css", "./style.css"],
    "./theme.css": "./theme.css"
  },
  "scripts": {
    "tsc": "tsc",
    "lint": "eslint",
    "create-icon-components": "tsx scripts/create-icon-components.ts",
    "build": "tsdown && pnpm run build:css",
    "build:css": "pnpm exec tailwindcss -i style.css -o dist/style.css",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "test": "vitest run --exclude \"src/scalars/**\"",
    "test:watch": "vitest watch",
    "chromatic": "npx chromatic --project-token=chpt_b9c79db0df52861"
