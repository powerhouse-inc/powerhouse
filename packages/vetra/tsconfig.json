{
  "extends": "../../tsconfig.options.json",
  "compilerOptions": {
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "types": ["node", "vitest/globals"],
    "lib": ["ESNext", "dom", "dom.iterable"],
    "paths": {
      "@powerhousedao/vetra/document-models": ["./document-models/index.ts"],
      "@powerhousedao/vetra/document-models/*": [
        "./document-models/*/index.ts"
      ],
      "@powerhousedao/vetra/editors": ["./editors/index.ts"],
      "@powerhousedao/vetra/editors/*": ["./editors/*/index.ts"],
      "@powerhousedao/vetra/processors": ["./processors/index.ts"],
      "@powerhousedao/vetra/processors/*": ["./processors/*/index.ts"]
    }
  },
  "include": ["**/*", "./powerhouse.manifest.json"],
  "exclude": ["dist", "node_modules", ".ph"],
  "references": [
    {
      "path": "../builder-tools"
    },
    {
      "path": "../codegen"
    },
    {
      "path": "../common"
    },
    {
      "path": "../config"
    },
    {
      "path": "../design-system"
    },
    {
      "path": "../document-model"
    },
    {
      "path": "../reactor-browser"
    },
    {
      "path": "../shared"
    }
  ]
}
