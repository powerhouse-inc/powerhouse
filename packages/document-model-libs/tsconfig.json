{
  "extends": "../../tsconfig.options.json",
  "compilerOptions": {
    "types": ["node", "vitest/globals", "@storybook/types"],
    "outDir": "./dist",
    "jsx": "react-jsx",
    "lib": ["ESNext", "dom", "dom.iterable"],
    "baseUrl": ".",
    "paths": {
      "document-model-libs/utils": ["./editors/utils"],
      "document-model-libs/utils/*": ["./editors/utils/*"],
      "@powerhousedao/design-system": ["../design-system/src"],
      "@powerhousedao/design-system/*": ["../design-system/src/*"],
      "document-model/document": ["../document-model/document/src"],
      "document-model/document/*": ["../document-model/document/src/*"],
      "document-model/document-model": ["../document-model/document-model/src"],
      "document-model/document-model/*": ["../document-model/document-model/src/*"],
    }
  },
  "references": [
    {
      "path": "../design-system",
    },
    {
      "path": "../document-model"
    }
  ],
  "include": [
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "document-models/**/*.ts",
    "editors/**/*.ts",
    "editors/**/*.tsx",
    "scripts/**/*.ts",
    "*.ts",
    "*.d.ts"
  ],
  "references": [
    {
      "path": "../design-system"
    }
  ]
}
