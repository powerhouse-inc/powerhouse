{
  "name": "@renown/sdk",
  "version": "6.2.2-dev.2",
  "description": "Renown SDK — wallet-based authentication and user identity management for Powerhouse React applications.",
  "license": "AGPL-3.0-only",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/powerhouse-inc/powerhouse",
    "directory": "packages/renown"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./node": {
      "source": "./src/node.ts",
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    },
    "./crypto": {
      "source": "./src/crypto.ts",
      "types": "./dist/crypto.d.ts",
      "import": "./dist/crypto.js",
      "default": "./dist/crypto.js"
    }
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "typesVersions": {
    "*": {
      "node": [
        "./dist/node.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "tsc": "tsc",
    "lint": "eslint"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@didtools/key-webcrypto": "^0.2.0",
    "@powerhousedao/shared": "workspace:*",
    "did-jwt-vc": "^4.0.12",
    "did-resolver": "^4.1.0",
    "key-did-resolver": "^4.0.0",
    "uint8arrays": "^5.1.0",
    "viem": "~2.50.4"
  },
  "keywords": [
    "powerhouse",
    "vetra",
    "document-model",
    "local-first",
    "event-sourcing",
    "renown",
    "authentication",
    "identity",
    "wallet",
    "web3",
    "react",
    "sdk"
  ],
  "homepage": "https://academy.vetra.io/academy/Reference/Authorization/renown-sdk/Overview"
}
