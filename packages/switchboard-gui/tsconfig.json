{
  "extends": "../../tsconfig.options.json",
  "compilerOptions": {
    "outDir": "./.tsbuild",
    "paths": {
      "react": [
        "./node_modules/preact/compat/"
      ],
      "react-dom": [
        "./node_modules/preact/compat/"
      ]
    },
    "jsxImportSource": "preact",
    "jsx": "preserve"
  },
  "include": [
    "**/*"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ],
  "references": [
    {
      "path": "../design-system"
    }
  ]
}
