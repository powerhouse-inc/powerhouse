{
  "name": "@powerhousedao/reactor-browser",
  "version": "6.2.0-dev.9",
  "license": "AGPL-3.0-only",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/powerhouse-inc/powerhouse"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "source": "./index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./analytics": {
      "source": "./src/analytics/index.ts",
      "types": "./dist/src/analytics/index.d.ts",
      "import": "./dist/src/analytics/index.js"
    },
    "./graphql": {
      "source": "./src/graphql/client.ts",
      "types": "./dist/src/graphql/client.d.ts",
      "import": "./dist/src/graphql/client.js"
    },
    "./relational": {
      "source": "./src/relational/index.ts",
      "types": "./dist/src/relational/index.d.ts",
      "import": "./dist/src/relational/index.js"
    },
    "./renown": {
      "source": "./src/renown/index.ts",
      "types": "./dist/src/renown/index.d.ts",
      "import": "./dist/src/renown/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "tsc": "tsc",
    "lint": "eslint",
    "build": "tsdown",
    "test": "vitest --run",
    "install:playwright": "playwright install",
    "codegen": "graphql-codegen --config codegen.ts && prettier --write src/graphql/gen/*.ts && eslint --fix src/graphql/gen/*.ts --no-warn-ignored"
  },
  "dependencies": {
    "@powerhousedao/analytics-engine-browser": "workspace:*",
    "@powerhousedao/analytics-engine-core": "workspace:*",
    "@powerhousedao/reactor": "workspace:*",
    "@powerhousedao/reactor-attachments": "workspace:*",
    "@powerhousedao/reactor-drive": "workspace:*",
    "@powerhousedao/shared": "workspace:*",
    "@renown/sdk": "workspace:*",
    "@tanstack/react-query": "^5.49.2",
    "change-case": "catalog:",
    "document-model": "workspace:*",
    "graphql-request": "catalog:",
    "kysely": "catalog:",
    "kysely-pglite-dialect": "catalog:",
    "lodash.isequal": "^4.5.0",
    "luxon": "^3.6.1",
    "lz-string": "^1.5.0",
    "normalize-exception": "^4.0.1",
    "remeda": "catalog:",
    "slug": "^11.0.0",
    "usehooks-ts": "^3.1.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@electric-sql/pglite": "catalog:",
    "@graphql-codegen/cli": "catalog:",
    "@graphql-codegen/typescript": "catalog:",
    "@graphql-codegen/typescript-graphql-request": "catalog:",
    "@graphql-codegen/typescript-operations": "catalog:",
    "@types/lodash.isequal": "^4.5.8",
    "@types/luxon": "^3.6.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/slug": "^5.0.9",
    "@types/wicg-file-system-access": "^2020.9.8",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "fast-deep-equal": "catalog:",
    "graphql": "catalog:",
    "graphql-tag": "catalog:",
    "playwright": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsdown": "catalog:",
    "type-fest": "catalog:",
    "viem": "~2.50.4",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vitest-browser-react": "^1.0.1"
  },
  "peerDependencies": {
    "graphql": "^16",
    "graphql-tag": "^2",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  }
}
