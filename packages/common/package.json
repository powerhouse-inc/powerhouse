  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "dependencies": {
    "graphql-request": "catalog:",
    "@powerhousedao/shared": "workspace:*",
    "@powerhousedao/reactor-browser": "workspace:*",
    "@powerhousedao/analytics-engine-core": "workspace:*",
    "luxon": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/luxon": "catalog:",
    "tsdown": "catalog:"
  }
}
