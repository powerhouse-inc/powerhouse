{
  "name": "@powerhousedao/common",
  "version": "6.2.0-dev.48",
  "license": "AGPL-3.0-only",
  "type": "module",
  "files": [
    "/dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/powerhouse-inc/powerhouse",
    "directory": "packages/common"
  },
  "exports": {
    ".": {
      "source": "./index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./utils": {
      "source": "./utils/index.ts",
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./analytics": {
      "source": "./drive-analytics.ts",
      "types": "./dist/drive-analytics.d.ts",
      "import": "./dist/drive-analytics.js"
    }
  },
  "sideEffects": false,
  "description": "Common Powerhouse package — base document model and drive UI components required for Connect and Vetra Studio.",
  "scripts": {
    "build": "tsdown",
    "tsc": "tsc",
    "lint": "eslint",
    "dev": "ph-cli dev --config-file ./powerhouse.config.json"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "dependencies": {
    "graphql-request": "catalog:",
    "@powerhousedao/shared": "workspace:*",
    "@powerhousedao/reactor-browser": "workspace:*",
    "@powerhousedao/analytics-engine-core": "workspace:*",
    "luxon": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/luxon": "catalog:",
    "tsdown": "catalog:"
  },
  "keywords": [
    "powerhouse",
    "vetra",
    "document-model",
    "local-first",
    "event-sourcing",
    "connect",
    "drive",
    "components"
  ],
  "homepage": "https://academy.vetra.io"
}
