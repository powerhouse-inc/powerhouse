{
  "name": "@powerhousedao/reactor",
  "version": "6.0.0-dev.141",
  "description": "",
  "repository": {
    "url": "https://github.com/powerhouse-inc/powerhouse",
    "directory": "packages/reactor"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:bundle": "tsdown",
    "test": "vitest run --coverage --printConsoleTrace=true --silent=false",
    "test:watch": "vitest --coverage",
    "lint": "eslint",
    "bench": "vitest bench --run",
    "bench:sync": "node --import tsx bench/two-reactor-sync.bench.ts",
    "clean": "rimraf dist",
    "clean:node_modules": "rimraf node_modules",
    "claude": "pnpm build && pnpm test && pnpm exec prettier --write \"**/*.ts\" && pnpm lint",
    "migrate": "tsx src/storage/migrations/run-migrations.ts",
    "migrate:status": "tsx src/storage/migrations/run-migrations.ts status"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [],
  "author": "",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "uuid": "^11.0.5",
    "kysely": "catalog:",
    "kysely-pglite-dialect": "catalog:",
    "@electric-sql/pglite": "catalog:",
    "@sindresorhus/fnv1a": "catalog:",
    "@powerhousedao/shared": "workspace:*",
    "document-model": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "catalog:",
    "prettier": "catalog:",
    "tinybench": "^2.9.0",
    "tsx": "catalog:",
    "vitest": "catalog:",
    "@types/bun": "catalog:",
    "tsdown": "catalog:",
    "vite-tsconfig-paths": "catalog:"
  }
}
