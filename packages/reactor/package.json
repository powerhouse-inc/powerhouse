{
  "name": "@powerhousedao/reactor",
  "version": "6.2.0-rc.0",
  "description": "Core Powerhouse reactor — stores documents, resolves conflicts, and reprocesses operation histories. Supports local, cloud, and decentralized storage backends.",
  "repository": {
    "url": "https://github.com/powerhouse-inc/powerhouse",
    "directory": "packages/reactor",
    "type": "git"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "source": "./index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run --coverage --printConsoleTrace=true --silent=false",
    "test:watch": "vitest --coverage",
    "lint": "eslint",
    "bench": "vitest bench --run",
    "bench:sync": "node --import tsx bench/two-reactor-sync.bench.ts",
    "clean": "rimraf dist",
    "clean:node_modules": "rimraf node_modules",
    "claude": "pnpm build && pnpm test && pnpm exec prettier --write \"**/*.ts\" && pnpm lint",
    "migrate": "tsx src/storage/migrations/run-migrations.ts",
    "migrate:status": "tsx src/storage/migrations/run-migrations.ts status",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "powerhouse",
    "vetra",
    "document-model",
    "local-first",
    "event-sourcing",
    "reactor",
    "cqrs",
    "decentralized",
    "sync"
  ],
  "author": "",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "uuid": "^14.0.0",
    "kysely": "catalog:",
    "kysely-pglite-dialect": "catalog:",
    "@electric-sql/pglite": "catalog:",
    "pg": "catalog:",
    "@sindresorhus/fnv1a": "catalog:",
    "@powerhousedao/shared": "workspace:*",
    "document-model": "workspace:*"
  },
  "devDependencies": {
    "@powerhousedao/pglite-fs": "workspace:*",
    "@types/pg": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "prettier": "catalog:",
    "tinybench": "^2.9.0",
    "tsx": "catalog:",
    "vitest": "catalog:",
    "@types/bun": "catalog:",
    "tsdown": "catalog:"
  },
  "homepage": "https://academy.vetra.io/academy/Reference/Reactor/WorkingWithTheReactor"
}
