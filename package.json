{
  "name": "root",
  "private": true,
  "type": "module",
  "scripts": {
    "tsc": "tsc",
    "test:ci": "CI=true pnpm --filter=document-model --filter=@powerhousedao/registry --filter=@powerhousedao/reactor-api --filter=@powerhousedao/reactor-hypercore --filter=@powerhousedao/reactor-mcp --filter=@powerhousedao/vetra --filter=@powerhousedao/versioned-documents --filter=@powerhousedao/switchboard --filter=@powerhousedao/connect --filter=@powerhousedao/design-system --filter=@powerhousedao/analytics-engine-core --filter=@powerhousedao/analytics-engine-graphql --filter=@powerhousedao/analytics-engine-knex --filter=@powerhousedao/load-test-connect --filter=ph-cmd --no-bail run test",
    "test:codegen": "pnpm --filter=test-codegen run test",
    "test:e2e:vetra": "pnpm --filter=test-package-vetra run test",
    "test:e2e:analytics": "pnpm --filter=@powerhousedao/analytics-engine-browser run test",
    "test:e2e:switchboard": "pnpm --filter=@powerhousedao/test-switchboard run test",
    "test:reactor": "pnpm --filter=@powerhousedao/reactor run test",
    "test:integration": "pnpm --filter=@powerhousedao/load-test-connect run test:integration",
    "test:browser": "pnpm --filter=@powerhousedao/reactor-browser run test",
    "test:pg": "pnpm --filter=@powerhousedao/analytics-engine-pg run test",
    "test-ci": "pnpm test:ci",
    "test-codegen": "pnpm test:codegen",
    "test-e2e": "pnpm test:e2e:vetra",
    "test-coverage": "pnpm vitest run --coverage",
    "simulate-ci-workflow": "pnpm clean && pnpm install-ci && pnpm check-ts-references && pnpm check-wrong-tsc-usage && pnpm build-tsc && pnpm build-misc && pnpm build-bundle && pnpm build-css && pnpm build-vite && pnpm install-ci && pnpm lint && pnpm test:ci && pnpm test:codegen && pnpm test:e2e:vetra && pnpm build-storybook && pnpm check-circular-imports",
    "lint": "NODE_OPTIONS=--max-old-space-size=8192 eslint --config eslint.config.js --quiet --fix --cache --cache-strategy content",
    "install-ci": "pnpm i --frozen-lockfile",
    "build-tsc": "tsc --build",
    "build-misc": "pnpm -r --no-bail build:misc",
    "build-css": "pnpm -r --no-bail build:css",
    "build-vite": "pnpm -r --no-bail build:vite",
    "build-cli": "pnpm -r --no-bail build:cli",
    "build-bundle": "pnpm -r --no-bail build:bundle",
    "build-storybook": "pnpm -r --no-bail run build:storybook",
    "clean": "bun x git clean -fdX",
    "build-all": "pnpm build-tsc && pnpm build-misc && pnpm build-bundle && pnpm build-css && pnpm build-vite && pnpm build-cli",
    "run-release": "bun run releases/release.ts",
    "run-release-safe": "pnpm run-release --verbose --skip-publish --skip-changelog --skip-push",
    "prepare": "husky",
    "check-circular-imports": "dpdm -T ./**/* --no-tree --no-warning --exit-code circular:1",
    "check-ts-references": "pnpm update-ts-references --check",
    "check-wrong-tsc-usage": "tsx scripts/check-wrong-tsc-usage.ts",
    "knip": "knip",
    "postinstall": "pnpm update-ts-references"
  },
  "devDependencies": {
    "@powerhousedao/ph-cli": "workspace:*",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.36.0",
    "@nx/devkit": "20.4.6",
    "@nx/js": "20.4.6",
    "@nx/plugin": "^20.4.6",
    "@swc-node/register": "~1.10.9",
    "@swc/core": "~1.11.1",
    "@types/node": "catalog:",
    "@types/semver": "^7.7.0",
    "@types/yargs": "^17.0.33",
    "dpdm": "^3.14.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^6.1.0",
    "glob": "^13.0.4",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "knip": "catalog:",
    "nx": "20.4.6",
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "read-pkg": "catalog:",
    "rimraf": "^6.0.1",
    "semver": "catalog:",
    "tsx": "catalog:",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.45.0",
    "update-ts-references": "^4.0.0",
    "vitest": "catalog:",
    "yargs": "^18.0.0"
  },
  "dependencies": {
    "@powerhousedao/connect": "workspace:*",
    "fast-glob": "^3.3.3"
  },
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "overrides": {
      "document-model": "link:./packages/document-model"
    }
  },
  "commitlint": {
    "rules": {
      "header-max-length": [
        2,
        "always",
        200
      ]
    }
  }
}
