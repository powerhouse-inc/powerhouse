{
  "name": "root",
  "private": true,
  "type": "module",
  "scripts": {
    "tsc": "tsc --build",
    "test": "pnpm test:ci",
    "test:ci": "CI=true pnpm --filter=document-model --filter=@powerhousedao/pglite-fs --filter=@powerhousedao/registry --filter=@powerhousedao/reactor-api --filter=@powerhousedao/reactor-hypercore --filter=@powerhousedao/reactor-mcp --filter=@powerhousedao/vetra --filter=@powerhousedao/versioned-documents --filter=@powerhousedao/switchboard --filter=@powerhousedao/connect --filter=@powerhousedao/design-system --filter=@powerhousedao/analytics-engine-core --filter=@powerhousedao/analytics-engine-graphql --filter=@powerhousedao/analytics-engine-knex --filter=@powerhousedao/load-test-connect --filter=ph-cmd --filter=@renown/sdk --no-bail run test",
    "test:codegen": "pnpm --filter=test-codegen run test",
    "test:e2e:vetra": "pnpm --filter=test-package-vetra run test",
    "test:e2e:package": "pnpm --filter=test-package-e2e run test",
    "test:integration:analytics": "pnpm --filter=@powerhousedao/analytics-engine-browser run test",
    "test:e2e:switchboard": "pnpm --filter=@powerhousedao/test-switchboard run test",
    "test:reactor": "pnpm --filter=@powerhousedao/reactor run test",
    "test:integration": "pnpm --filter=@powerhousedao/load-test-connect run test:integration",
    "test:browser": "pnpm --filter=@powerhousedao/reactor-browser run test",
    "test:pg": "pnpm --filter=@powerhousedao/analytics-engine-pg run test",
    "test:coverage": "pnpm vitest run --coverage",
    "simulate-ci-workflow": "pnpm clean && pnpm install-ci && pnpm check-ts-references && pnpm typecheck && pnpm build && pnpm typecheck:consumers && pnpm rebuild --recursive && pnpm --filter=@powerhousedao/versioned-documents --no-bail run build && pnpm lint && pnpm test:ci && pnpm test:codegen && pnpm test:e2e:vetra && pnpm test:e2e:package && pnpm build:storybook && pnpm check-circular-imports",
    "simulate-ci-workflow-reactor": "pnpm simulate-ci-workflow && pnpm test:reactor && pnpm test:integration",
    "lint": "pnpm build:css && oxlint --type-aware && oxfmt --check .",
    "lint:fix": "pnpm build:css && oxlint --type-aware --fix && oxfmt --write .",
    "build:css": "pnpm --filter=@powerhousedao/design-system --filter=@powerhousedao/vetra --filter=@powerhousedao/powerhouse-vetra-packages --filter=@powerhousedao/connect run build:css",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "install-ci": "pnpm i --frozen-lockfile",
    "build": "pnpm --filter=@powerhousedao/config --filter=@renown/sdk --filter=@powerhousedao/common --filter=@powerhousedao/builder-tools --filter=@powerhousedao/codegen --filter=document-model --filter=@powerhousedao/design-system --filter=@powerhousedao/powerhouse-vetra-packages --filter=@powerhousedao/pglite-fs --filter=@powerhousedao/reactor-api --filter=@powerhousedao/reactor-attachments --filter=@powerhousedao/reactor-browser --filter=@powerhousedao/reactor --filter=@powerhousedao/reactor-drive --filter=@powerhousedao/reactor-hypercore --filter=@powerhousedao/reactor-mcp --filter=@powerhousedao/opentelemetry-instrumentation-reactor --filter=@powerhousedao/registry --filter=@powerhousedao/shared --filter=@powerhousedao/switchboard-gui --filter=@powerhousedao/vetra --filter=@powerhousedao/analytics-engine-browser --filter=@powerhousedao/analytics-engine-core --filter=@powerhousedao/analytics-engine-graphql --filter=@powerhousedao/analytics-engine-knex --filter=@powerhousedao/analytics-engine-pg --filter=@powerhousedao/connect --filter=@powerhousedao/switchboard --filter=@powerhousedao/ph-cli --filter=ph-cmd --filter=@powerhousedao/load-test-client --filter=@powerhousedao/load-test-connect --filter=@powerhousedao/e2e-utils --no-bail run build",
    "typecheck": "tsc --build",
    "typecheck:tsgo": "tsgo --build tsconfig.tsgo.json",
    "typecheck:consumers": "tsc --build test/test-consumer-project",
    "build:storybook": "pnpm --filter=@powerhousedao/design-system run build:storybook",
    "clean": "bun x git clean -fdX",
    "run-release": "bun run releases/release.ts",
    "run-release-safe": "pnpm run-release --verbose --skip-publish --skip-changelog --skip-push",
    "release-wizard": "tsx scripts/release/index.ts",
    "prepare": "husky",
    "check-circular-imports": "dpdm -T ./**/* --no-tree --no-warning --exit-code circular:1",
    "check-ts-references": "pnpm update-ts-references --check",
    "knip": "knip",
    "postinstall": "pnpm update-ts-references",
    "add-tailwind-darkmode-classes": "tsx scripts/add-tailwind-darkmode-classes.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@nx/devkit": "22.7.1",
    "@nx/js": "22.7.1",
    "@nx/plugin": "^22.7.1",
    "@oxlint/plugins": "^1.65.0",
    "@powerhousedao/ph-cli": "workspace:*",
    "@swc-node/register": "~1.10.9",
    "@swc/core": "~1.11.1",
    "@types/node": "catalog:",
    "@types/semver": "^7.7.0",
    "@types/yargs": "^17.0.33",
    "@typescript/native-preview": "7.0.0-dev.20260518.1",
    "dpdm": "^4.2.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "glob": "^13.0.4",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "knip": "catalog:",
    "nx": "22.7.1",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "oxlint-tailwindcss": "^0.8.0",
    "oxlint-tsgolint": "^0.23.0",
    "read-pkg": "catalog:",
    "remeda": "catalog:",
    "rimraf": "^6.0.1",
    "semver": "catalog:",
    "ts-morph": "catalog:",
    "tsx": "catalog:",
    "type-fest": "catalog:",
    "typescript": "6.0.3",
    "update-ts-references": "^6.0.0",
    "vitest": "catalog:",
    "yargs": "^18.0.0"
  },
  "dependencies": {
    "@powerhousedao/connect": "workspace:*",
    "fast-glob": "^3.3.3"
  },
  "engines": {
    "node": ">=24"
  },
  "commitlint": {
    "rules": {
      "header-max-length": [
        2,
        "always",
        200
      ]
    }
  }
}
