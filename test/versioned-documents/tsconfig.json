{
  "compilerOptions": {
    "composite": true,
    "customConditions": ["source"],
    "rootDir": ".",
    // paths for easy access to project modules
    "paths": {
      "document-models": ["./document-models/index.ts"],
      "document-models/*": ["./document-models/*/index.ts"],
      "editors": ["./editors/index.ts"],
      "editors/*": ["./editors/*/index.ts"],
      "processors/*": ["./processors/*/index.ts"],
      "subgraphs": ["./subgraphs/index.ts"],
      "subgraphs/*": ["./subgraphs/*/index.ts"]
    },
    "module": "nodenext",
    "moduleDetection": "force",
    "target": "esnext",
    "jsx": "react-jsx",
    "types": ["node", "vite/client", "vitest/globals"],
    "lib": ["ESNext", "dom", "dom.iterable"],
    "declaration": true,
    "declarationDir": "./.tsbuild",
    "tsBuildInfoFile": "./.tsbuild/tsconfig.tsbuildinfo",
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "incremental": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "skipLibCheck": true
  },
  "include": ["**/*", "./powerhouse.manifest.json"],
  "exclude": ["dist", "node_modules", ".ph", "vitest.config.ts"],
  "references": [
    {
      "path": "../../apps/connect"
    },
    {
      "path": "../../clis/ph-cli"
    },
    {
      "path": "../../packages/analytics-engine/core"
    },
    {
      "path": "../../packages/design-system"
    },
    {
      "path": "../../packages/document-model"
    },
    {
      "path": "../../packages/reactor"
    },
    {
      "path": "../../packages/reactor-api"
    },
    {
      "path": "../../packages/reactor-browser"
    },
    {
      "path": "../../packages/shared"
    }
  ]
}
