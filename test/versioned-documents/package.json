{
  "name": "@powerhousedao/versioned-documents",
  "version": "5.1.0-dev.26",
  "license": "AGPL-3.0-only",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/powerhouse-inc/powerhouse"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "source": "./index.ts",
      "browser": "./dist/browser/index.js",
      "node": "./dist/node/index.js"
    },
    "./document-models": {
      "source": "./document-models/index.ts",
      "browser": "./dist/browser/document-models/index.js",
      "node": "./dist/node/document-models/index.js"
    },
    "./document-models/*": {
      "source": "./document-models/*/index.ts",
      "browser": "./dist/browser/document-models/*/index.js",
      "node": "./dist/node/document-models/*/index.js"
    },
    "./editors": {
      "source": "./editors/index.ts",
      "browser": "./dist/browser/editors/index.js",
      "node": "./dist/node/editors/index.js"
    },
    "./editors/*": {
      "source": "./editors/*/index.ts",
      "browser": "./dist/browser/editors/*/index.js",
      "node": "./dist/node/editors/*/index.js"
    },
    "./subgraphs": {
      "source": "./dist/subgraphs/index.ts",
      "browser": "./dist/browser/subgraphs/index.js",
      "node": "./dist/node/subgraphs/index.js"
    },
    "./processors": {
      "source": "./processors/index.ts",
      "browser": "./dist/browser/processors/index.js",
      "node": "./dist/node/processors/index.js"
    },
    "./manifest": "./dist/powerhouse.manifest.json",
    "./style.css": "./dist/style.css"
  },
  "sideEffects": false,
  "scripts": {
    "create:todo": "tsx scripts/create-versioned-todo.ts && ph-cli generate ./scripts/versioned-todo.zip --use-versioning",
    "tsc": "tsc",
    "lint": "eslint",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:document-models": "vitest run document-models",
    "test:editors": "vitest run editors",
    "test:processors": "vitest run processors",
    "build": "ph-cli build",
    "generate": "ph-cli generate",
    "connect": "ph-cli connect",
    "reactor": "ph-cli reactor",
    "service": "ph-cli service",
    "migrate": "ph-cli migrate",
    "service-startup": "bash ./node_modules/@powerhousedao/ph-cli/dist/scripts/service-startup.sh",
    "service-unstartup": "bash ./node_modules/@powerhousedao/ph-cli/dist/scripts/service-unstartup.sh"
  },
  "dependencies": {
    "document-model": "workspace:*",
    "@powerhousedao/design-system": "workspace:*",
    "@powerhousedao/reactor": "workspace:*",
    "@powerhousedao/reactor-browser": "workspace:*",
    "@powerhousedao/connect": "workspace:*",
    "@powerhousedao/analytics-engine-core": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@powerhousedao/ph-cli": "workspace:*",
    "tsdown": "catalog:",
    "@tailwindcss/cli": "catalog:",
    "tailwindcss": "catalog:",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "vitest": "catalog:",
    "vite-tsconfig-paths": "catalog:"
  },
  "description": ""
}
