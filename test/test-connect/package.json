{
  "name": "@powerhousedao/load-test-connect",
  "version": "1.0.0",
  "description": "Load testing CLI that simulates Connect sync to a Switchboard",
  "license": "AGPL-3.0-only",
  "type": "module",
  "private": true,
  "bin": {
    "ph-load-test-connect": "dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "types": "./dist/index.d.mts",
  "scripts": {
    "build": "tsdown",
    "dev": "tsx src/cli.ts",
    "test": "vitest --run",
    "scenario:sync": "tsx src/orchestrator.ts",
    "scenario:sync:stress": "tsx src/orchestrator.ts --clients 5 --duration 120000 --mutation-interval 200",
    "analyze": "tsx src/analyze-logs.ts",
    "test:integration": "tsx src/run-integration.ts"
  },
  "dependencies": {
    "@powerhousedao/reactor": "workspace:*",
    "@powerhousedao/load-test-client": "workspace:*",
    "document-model": "workspace:*",
    "@powerhousedao/shared": "workspace:*",
    "colorette": "catalog:",
    "commander": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  }
}
