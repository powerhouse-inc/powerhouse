{
  "extends": "../../tsconfig.options.json",
  "compilerOptions": {
    "outDir": "./dist",
    "resolveJsonModule": true,
    "paths": {
      "connect-e2e/document-models": [
        "./document-models/index.ts"
      ],
      "connect-e2e/document-models/*": [
        "./document-models/*/index.ts"
      ],
      "connect-e2e/editors": [
        "./editors/index.ts"
      ],
      "connect-e2e/editors/*": [
        "./editors/*/index.ts"
      ],
      "connect-e2e/processors": [
        "./processors/index.ts"
      ],
      "connect-e2e/processors/*": [
        "./processors/*/index.ts"
      ]
    }
  },
  "references": [
    {
      "path": "../../apps/connect"
    },
    {
      "path": "../../apps/switchboard"
    },
    {
      "path": "../../clis/ph-cli"
    },
    {
      "path": "../../packages/builder-tools"
    },
    {
      "path": "../../packages/design-system"
    },
    {
      "path": "../../packages/document-model"
    },
    {
      "path": "../../packages/reactor-browser"
    },
    {
      "path": "../e2e-utils"
    }
  ],
  "include": [
    "**/*",
    "powerhouse.manifest.json"
  ]
}
