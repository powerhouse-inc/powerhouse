{
  "extends": "../../tsconfig.options.json",
  "compilerOptions": {
    "outDir": "./dist",
    "types": [
      "@types/bun"
    ],
    "paths": {
      "test-project/document-models": [
        "./document-models/index.ts"
      ],
      "test-project/document-models/*": [
        "./document-models/*/index.ts"
      ],
      "test-project/editors": [
        "./editors/index.ts"
      ],
      "test-project/editors/*": [
        "./editors/*/index.ts"
      ]
    }
  },
  "include": [
    "**/*"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "test-output",
    "test-projects"
  ],
  "references": [
    {
      "path": "../../apps/connect"
    },
    {
      "path": "../../packages/analytics-engine/core"
    },
    {
      "path": "../../packages/codegen"
    },
    {
      "path": "../../packages/common"
    },
    {
      "path": "../../packages/config"
    },
    {
      "path": "../../packages/design-system"
    },
    {
      "path": "../../packages/document-model"
    },
    {
      "path": "../../packages/reactor"
    },
    {
      "path": "../../packages/reactor-api"
    },
    {
      "path": "../../packages/reactor-browser"
    },
    {
      "path": "../../packages/shared"
    }
  ]
}
