{
  "extends": "../../tsconfig.options.json",
  "compilerOptions": {
    "outDir": "./dist",
    "resolveJsonModule": true,
    "types": ["node", "vite/client", "vitest/globals"],
    "paths": {
      "document-models": [
        "./document-models/index.ts"
      ],
      "document-models/*": [
        "./document-models/*/index.ts"
      ],
      "editors": [
        "./editors/index.ts"
      ],
      "editors/*": [
        "./editors/*/index.ts"
      ],
      "processors": [
        "./processors/index.ts"
      ],
      "processors/*": [
        "./processors/*/index.ts"
      ],
      "subgraphs": [
        "./subgraphs/index.ts"
      ],
      "subgraphs/*": [
        "./subgraphs/*/index.ts"
      ]
    }
  },
  "references": [
    {
      "path": "../../apps/connect"
    },
    {
      "path": "../../clis/ph-cli"
    },
    {
      "path": "../../packages/design-system"
    },
    {
      "path": "../../packages/document-model"
    },
    {
      "path": "../../packages/reactor-browser"
    },
    {
      "path": "../../packages/registry"
    },
    {
      "path": "../e2e-utils"
    },
    {
      "path": "../versioned-documents"
    }
  ],
  "include": [
    "**/*",
    "powerhouse.manifest.json"
  ],
  "exclude": [
    "dist",
    "node_modules",
    ".ph"
  ]
}
