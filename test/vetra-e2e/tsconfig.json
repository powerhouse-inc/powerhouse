{
  "extends": "../../tsconfig.options.json",
  "compilerOptions": {
    "outDir": "./dist",
    "resolveJsonModule": true,
        "paths": {
      "test-package-vetra/document-models": [
        "./document-models/index.ts"
      ],
      "test-package-vetra/document-models/*": [
        "./document-models/*/index.ts"
      ],
      "test-package-vetra/editors": [
        "./editors/index.ts"
      ],
      "test-package-vetra/editors/*": [
        "./editors/*/index.ts"
      ],
      "test-package-vetra/processors": [
        "./processors/index.ts"
      ],
      "test-package-vetra/processors/*": [
        "./processors/*/index.ts"
      ]
    }
  },
  "references": [
    {
      "path": "../../apps/connect"
    },
    {
      "path": "../../clis/ph-cli"
    },
    {
      "path": "../../packages/builder-tools"
    },
    {
      "path": "../../packages/codegen"
    },
    {
      "path": "../../packages/common"
    },
    {
      "path": "../../packages/config"
    },
    {
      "path": "../../packages/design-system"
    },
    {
      "path": "../../packages/document-drive"
    },
    {
      "path": "../../packages/document-model"
    },
    {
      "path": "../../packages/reactor-browser"
    },
    {
      "path": "../../packages/shared"
    },
    {
      "path": "../../packages/vetra"
    },
    {
      "path": "../e2e-utils"
    }
  ],
  "include": [
    "**/*",
    "powerhouse.manifest.json"
  ],
  "exclude": [
    "dist",
    "node_modules",
    ".ph"
  ]
}
