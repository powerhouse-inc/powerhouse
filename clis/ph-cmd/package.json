{
  "name": "ph-cmd",
  "version": "6.2.0-rc.2",
  "description": "Powerhouse CLI — create Vetra projects, generate document models and editors, run local dev environments, and publish packages.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/powerhouse-inc/powerhouse",
    "directory": "clis/ph-cmd"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "ph": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "tsc": "tsc",
    "lint": "eslint",
    "generate-docs": "bun run scripts/generate-commands-docs.ts",
    "build": "tsdown",
    "postbuild": "bun generate-docs",
    "dev": "bun run ./src/cli.ts",
    "cli": "node ./dist/cli.mjs",
    "test": "vitest --run",
    "test:watch": "vitest watch"
  },
  "keywords": [
    "powerhouse",
    "vetra",
    "document-model",
    "local-first",
    "event-sourcing",
    "cli",
    "scaffold",
    "codegen",
    "ph-cmd"
  ],
  "author": "",
  "dependencies": {
    "@powerhousedao/shared": "workspace:*",
    "@sentry/node-core": "^10.52.0",
    "chalk": "catalog:",
    "cmd-ts": "catalog:",
    "package-manager-detector": "catalog:",
    "read-pkg": "catalog:",
    "semver": "catalog:",
    "write-package": "catalog:"
  },
  "devDependencies": {
    "@powerhousedao/codegen": "workspace:*",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "homepage": "https://academy.vetra.io/academy/Reference/CLITooling/PowerhouseCLI"
}
