-            if (context.isVerbose) {
+            // Patched: pnpm sometimes emits {error:{...}} without summary/detail/code/message
+            // (or with empty/unknown fields). Without this, the executor logs a bare
+            // "pnpm publish error:" and swallows the actual failure. Surface raw stderr
+            // and the full parsed payload so failures are diagnosable from CI logs.
+            const hasRecognizedField = stdoutData.error?.summary ||
+                stdoutData.error?.detail ||
+                stdoutData.error?.code ||
+                stdoutData.error?.message;
+            if (!hasRecognizedField) {
+                const stderrStr = err.stderr?.toString() || '';
+                if (stderrStr.trim().length > 0) {
+                    console.error(stderrStr);
+                }
+                console.error(`${pm} publish stdout:`);
+                console.error(JSON.stringify(stdoutData, null, 2));
+            }
+            else if (context.isVerbose) {
                 console.error(`${pm} publish stdout:`);
                 console.error(JSON.stringify(stdoutData, null, 2));
             }
