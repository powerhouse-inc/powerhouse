{
  "extends": "../../tsconfig.options.json",
  "compilerOptions": {
    "outDir": "./dist",
    "emitDeclarationOnly": true,
    "paths": {
      "@powerhousedao/connect/config": ["./src/connect.config.ts"],
      "@powerhousedao/connect/assets/icons/*": ["./assets/icons/*"],
      "@powerhousedao/connect/*": ["./src/*/index.ts"],
      "@powerhousedao/connect/package.json": ["./package.copy.json"]
    },
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "node",
      "@types/wicg-file-system-access",
      "@types/bun"
    ]
  },
  "include": [
    "**/*",
    "src/i18n/locales/en.json",
    "./package.copy.json"
  ],
  "exclude": [
    "dist",
    "lib",
    "node_modules",
    "storybook-static"
  ],
  "references": [
    {
      "path": "../../packages/builder-tools"
    },
    {
      "path": "../../packages/config"
    },
    {
      "path": "../../packages/design-system"
    },
    {
      "path": "../../packages/document-drive"
    },
    {
      "path": "../../packages/document-model"
    },
    {
      "path": "../../packages/powerhouse-vetra-packages"
    },
    {
      "path": "../../packages/reactor"
    },
    {
      "path": "../../packages/reactor-browser"
    },
    {
      "path": "../../packages/renown"
    },
    {
      "path": "../../packages/shared"
    }
  ]
}
