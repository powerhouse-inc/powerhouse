# Connect runtime behavior is not configured via env vars — set those
# values in `apps/connect/public/powerhouse.config.json` (or via
# `ph connect config --<field>`). The Sentry DSN / env / tracing flag
# live in `connect.sentry.*` of that file as of issue #2646.

# Sentry source-map upload credentials (build-time only).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Analytics processor wiring (optional overrides; defaults work for dev).
PH_CONNECT_DIFF_ANALYTICS_ENABLED="false"
PH_CONNECT_DRIVE_ANALYTICS_ENABLED="true"

## openpanel analytics
# OpenPanel client ID; empty disables the OpenPanel subsystem
PH_CONNECT_OPENPANEL_CLIENT_ID=""
# OpenPanel API URL override; defaults to OpenPanel cloud when unset
PH_CONNECT_OPENPANEL_API_URL=""
# Track UI events via the useOpenPanel() hook
PH_CONNECT_OPENPANEL_TRACK_UI_EVENTS="true"
# Track document operations via the OpenPanel processor
PH_CONNECT_OPENPANEL_TRACK_OPERATIONS="true"
