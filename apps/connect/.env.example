# Sentry secrets and per-deploy stamps. KEEP-category env vars from the
# §2.1 audit. Everything else that used to control Connect runtime
# behavior now lives in `apps/connect/public/powerhouse.config.json`.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Analytics processor wiring (optional overrides; defaults work for dev).
PH_CONNECT_DIFF_ANALYTICS_ENABLED="false"
PH_CONNECT_DRIVE_ANALYTICS_ENABLED="true"

## error tracking
PH_CONNECT_SENTRY_DSN=""
PH_CONNECT_SENTRY_ENV="dev"
PH_CONNECT_SENTRY_TRACING_ENABLED="false"
