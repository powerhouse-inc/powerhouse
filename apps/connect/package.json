{
  "name": "@powerhousedao/connect",
  "productName": "Powerhouse-Connect",
  "version": "6.2.0-dev.40",
  "description": "Powerhouse Connect",
  "main": "dist/index.html",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist",
    "style.css",
    "nginx.conf",
    "nginx.sh",
    "scripts",
    "assets",
    "public",
    "heroku",
    ".env"
  ],
  "exports": {
    ".": {
      "source": "./start-connect.tsx",
      "types": "./dist/start-connect.d.ts",
      "import": "./dist/start-connect.js"
    },
    "./main.js": {
      "source": "./main.tsx",
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    },
    "./assets/*": "./assets/*",
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "./dist/main.js",
    "./dist/start-connect.js",
    "./dist/i18n-*.js",
    "./dist/style.css"
  ],
  "license": "AGPL-3.0-only",
  "author": "powerhouse.inc",
  "repository": {
    "type": "git",
    "url": "https://github.com/powerhouse-inc/powerhouse"
  },
  "bugs": {
    "url": "https://github.com/powerhouse-inc/powerhouse/issues"
  },
  "homepage": "https://github.com/powerhouse-inc/powerhouse#readme",
  "scripts": {
    "tsc": "tsc",
    "lint": "eslint",
    "test": "vitest --run",
    "dev": "vite dev",
    "build": "pnpm run build:bundle && pnpm run build:css",
    "build:bundle": "tsdown",
    "build:css": "pnpm exec tailwindcss -i style.css -o dist/style.css",
    "build:debug": "PH_DEBUG_BUILD=true vite build",
    "preview": "vite preview",
    "cy:open": "cypress open",
    "docker:build": "docker build -f ./Dockerfile --tag connect-test-dev --build-arg TAG=dev .",
    "docker:run": "docker run -it -p 4000:4000 -v $(realpath ../../../monorepo):/monorepo -v $(pwd)/nginx.conf:/etc/nginx/nginx.conf.template -e PH_CONNECT_BASE_PATH=/develop/powerhouse/connect -e PORT=4000 connect-test-dev"
  },
  "dependencies": {
    "@electric-sql/pglite": "catalog:",
    "@electric-sql/pglite-tools": "catalog:",
    "@openfeature/core": "1.9.1",
    "@openfeature/web-sdk": "1.6.2",
    "@openpanel/web": "^1.4.1",
    "@powerhousedao/config": "workspace:*",
    "@powerhousedao/design-system": "workspace:*",
    "@powerhousedao/document-engineering": "catalog:",
    "@powerhousedao/powerhouse-vetra-packages": "workspace:*",
    "@powerhousedao/reactor": "workspace:*",
    "@powerhousedao/reactor-attachments": "workspace:*",
    "@powerhousedao/reactor-browser": "workspace:*",
    "@powerhousedao/shared": "workspace:*",
    "@powerhousedao/vetra": "workspace:*",
    "@renown/sdk": "workspace:*",
    "@sentry/react": "^10.17.0",
    "document-model": "workspace:*",
    "i18next": "^25.5.3",
    "kysely": "catalog:",
    "kysely-pglite-dialect": "catalog:",
    "lucide-react": "^1.16.0",
    "pglite-legacy-02": "npm:@electric-sql/pglite@0.2.17",
    "pglite-tools-legacy-02": "npm:@electric-sql/pglite-tools@0.2.4",
    "react-error-boundary": "^4.0.11",
    "react-hotkeys-hook": "^4.6.2",
    "react-i18next": "^16.0.0",
    "react-router-dom": "^6.11.2",
    "tailwind-merge": "catalog:",
    "usehooks-ts": "^3.1.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/cli": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.0.1",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/wicg-file-system-access": "^2023.10.7",
    "@vitejs/plugin-react": "catalog:",
    "cypress": "^14.5.4",
    "happy-dom": "^20.8.9",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "catalog:",
    "tsdown": "catalog:",
    "vite": "catalog:",
    "vite-bundle-analyzer": "^1.3.6",
    "vite-tsconfig-paths": "catalog:"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  }
}
