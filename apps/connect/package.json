{
  "name": "@powerhousedao/connect",
  "productName": "Powerhouse-Connect",
  "version": "6.0.0-dev.97",
  "description": "Powerhouse Connect",
  "main": "dist/index.html",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist",
    "nginx.conf",
    "nginx.sh",
    "scripts",
    "assets",
    "public",
    "heroku",
    ".env"
  ],
  "exports": {
    "./main.js": {
      "types": "./dist/src/main.d.ts",
      "import": "./dist/src/main.js"
    },
    "./config": {
      "import": "./dist/src/connect.config.js",
      "types": "./dist/src/connect.config.d.ts"
    },
    "./assets/*": "./assets/*",
    "./style.css": "./dist/style.css",
    "./package.json": {
      "import": "./dist/package.copy.json",
      "types": "./dist/src/package-json.d.ts"
    },
    "./*": {
      "types": "./dist/src/*/index.d.ts",
      "import": "./dist/src/*/index.js"
    }
  },
  "sideEffects": [
    "./dist/src/main.js",
    "./dist/style.css"
  ],
  "license": "AGPL-3.0-only",
  "author": "powerhouse.inc",
  "repository": {
    "type": "git",
    "url": "https://github.com/powerhouse-inc/powerhouse"
  },
  "bugs": {
    "url": "https://github.com/powerhouse-inc/powerhouse/issues"
  },
  "homepage": "https://github.com/powerhouse-inc/powerhouse#readme",
  "scripts": {
    "tsc": "tsc",
    "lint": "eslint",
    "test": "vitest --run",
    "dev": "vite dev",
    "build:css": "pnpm exec tailwindcss -i ./src/index.css -o ./dist/style.css",
    "build:connect": "pnpm tsc && cp package.json dist/package.copy.json && pnpm build:css",
    "build:all": "pnpm build:css && pnpm build:connect",
    "build:debug": "PH_DEBUG_BUILD=true vite build",
    "preview": "vite preview",
    "cy:open": "cypress open",
    "docker:build": "docker build -f ./Dockerfile --tag connect-test-dev --build-arg TAG=dev .",
    "docker:run": "docker run -it -p 4000:4000 -v $(realpath ../../../monorepo):/monorepo -v $(pwd)/nginx.conf:/etc/nginx/nginx.conf.template -e PH_USE_LOCAL=true -e PH_CONNECT_BASE_PATH=/develop/powerhouse/connect -e PORT=4000 connect-test-dev"
  },
  "dependencies": {
    "@openfeature/web-sdk": "1.6.2",
    "@powerhousedao/design-system": "workspace:*",
    "@powerhousedao/powerhouse-vetra-packages": "workspace:*",
    "@powerhousedao/reactor-browser": "workspace:*",
    "@powerhousedao/shared": "workspace:",
    "@renown/sdk": "workspace:*",
    "@sentry/react": "^10.17.0",
    "graphql-request": "catalog:",
    "i18next": "^25.5.3",
    "kysely": "catalog:",
    "kysely-pglite-dialect": "catalog:",
    "react-error-boundary": "^4.0.11",
    "react-hotkeys-hook": "^4.6.2",
    "react-i18next": "^16.0.0",
    "react-router-dom": "^6.11.2",
    "tailwind-merge": "catalog:"
  },
  "devDependencies": {
    "@electric-sql/pglite": "catalog:",
    "@electric-sql/pglite-tools": "catalog:",
    "@openfeature/core": "1.9.1",
    "@powerhousedao/builder-tools": "workspace:*",
    "@powerhousedao/config": "workspace:*",
    "@powerhousedao/document-engineering": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/wicg-file-system-access": "^2023.10.7",
    "@types/bun": "catalog:",
    "cypress": "^14.5.4",
    "document-drive": "workspace:*",
    "document-model": "workspace:*",
    "graphql": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "catalog:",
    "@tailwindcss/cli": "catalog:",
    "vite": "catalog:",
    "vite-bundle-analyzer": "^1.3.6",
    "vite-plugin-svgr": "catalog:",
    "vite-tsconfig-paths": "^6.1.1",
    "tsconfig-paths": "4.2.0"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "@electric-sql/pglite": ">=0.3.15",
    "@electric-sql/pglite-tools": ">=0.2.20",
    "document-drive": "workspace:*",
    "document-model": "workspace:*"
  }
}
