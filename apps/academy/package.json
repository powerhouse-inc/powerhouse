{
  "name": "@powerhousedao/academy",
  "version": "6.2.0-dev.32",
  "homepage": "https://powerhouse.academy",
  "packageManager": "pnpm@10.9.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/powerhouse-inc/powerhouse"
  },
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus serve",
    "dev": "docusaurus start --no-open",
    "build": "NODE_OPTIONS=--max_old_space_size=2048 docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "generate:docs": "pnpm generate:cli-docs && pnpm generate:recipe-docs && pnpm generate:llm-docs",
    "generate:cli-docs": "tsx ./scripts/generate-combined-cli-docs.ts",
    "generate:recipe-docs": "tsx ./scripts/generate-recipe-docs.ts",
    "generate:llm-docs": "tsx ./scripts/generate-llm-docs.ts",
    "check:doc-snippets": "tsx ./scripts/check-doc-snippets.ts",
    "heroku-postbuild": "npm run build",
    "slides:preview": "marp -s ./slides",
    "slides:build": "marp ./slides"
  },
  "dependencies": {
    "@codesandbox/sandpack-react": "^2.14.4",
    "@docusaurus/core": "3.10.0",
    "@docusaurus/faster": "3.10.0",
    "@docusaurus/plugin-content-docs": "3.10.0",
    "@docusaurus/preset-classic": "3.10.0",
    "@docusaurus/theme-search-algolia": "3.10.0",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.3.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.0",
    "@docusaurus/plugin-client-redirects": "3.10.0",
    "@docusaurus/tsconfig": "3.10.0",
    "@docusaurus/types": "3.10.0",
    "@marp-team/marp-cli": "^4.2.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "tsx": "4.21.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  }
}
